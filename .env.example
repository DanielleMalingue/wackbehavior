# ─── Firebase (client) ───────────────────────────────────────────────
# Already configured in your .env.local.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server) ─────────────────────────────────────────
# Service-account JSON for verifying users + writing Firestore from the server.
# Firebase Console → Project settings → Service accounts → Generate new private
# key. Paste the JSON as one line, or base64-encode it.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys (use test keys while testing).
STRIPE_SECRET_KEY=sk_test_...
# From the webhook endpoint you create (Developers → Webhooks), or from the
# Stripe CLI `stripe listen` output when testing locally.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ─────────────────────────────────────────────────────────────
# Used for Checkout success/cancel + portal return URLs when the request has
# no Origin header. Set to your production URL on Vercel.
NEXT_PUBLIC_APP_URL=http://localhost:3000
